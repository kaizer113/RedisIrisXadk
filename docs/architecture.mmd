%%{init: {"theme":"base","themeVariables":{"background":"#ffffff","primaryTextColor":"#111827","lineColor":"#334155","clusterBkg":"#f8fafc","clusterBorder":"#94a3b8"},"flowchart":{"curve":"basis"}}}%%
flowchart TB
    browser["Browser chat UI<br/>model selector · answer · live trace"]

    subgraph gcp["GCP · us-east4"]
        direction TB
        subgraph run["Public application · FastAPI"]
            direction LR
            api["Chat API"] --> prefetch["Parallel read prefetch"]
            prefetch --> gate{"LangCache hit?"}
            gate -->|hit| cached["Cached response<br/>skip ADK + Gemini"]
            gate -->|miss or bypass| runners["Shared ADK services<br/>Flash Runner · Pro Runner"]
            runners --> tools["Commerce, context,<br/>cart and memory tools"]
        end

        subgraph vertex["Vertex AI / Agent Platform"]
            direction LR
            gemini["Gemini 2.5<br/>Flash or Pro"]
            sessions["Agent Platform Sessions<br/>VertexAiSessionService"]
            bank["ADK Memory Bank<br/>retrieve + post-turn promote"]
        end
    end

    subgraph iris["Redis IRIS / Redis Cloud"]
        direction LR
        rdi["Redis Data Integration<br/>continuous synchronization"]
        cache["LangCache<br/>public policy answers"]
        ram["Redis Agent Memory<br/>session events + long-term facts"]
        context["Context Retriever<br/>governed live-data tools"]
        database["Redis database + Query Engine<br/>catalog, policy, cart, commerce data"]
    end

    lake[("Persistent enterprise data lake<br/>hypothetical · not part of demo")]

    browser -->|HTTP + streamed NDJSON| api

    prefetch -->|eligible query| cache
    cache -->|hit or miss| gate
    prefetch -->|recent events + recall| ram
    prefetch -->|long-term recall| bank

    runners --> gemini
    runners -->|session read + append| sessions
    runners -->|post-turn promotion| bank
    tools --> context
    tools --> database
    tools --> ram
    context --> database
    api -->|explicit user + assistant events| ram

    cache --> database
    ram --> database
    lake -->|source records| rdi
    rdi -->|continuous sync| database

    classDef client fill:#f2f7ff,stroke:#2864dc,color:#102a43
    classDef app fill:#fff4e8,stroke:#d97706,color:#4a2500
    classDef google fill:#eef6ff,stroke:#4285f4,color:#17365d
    classDef redis fill:#fff0f0,stroke:#dc382d,color:#4a1512
    classDef external fill:#f2fbf3,stroke:#2f855a,color:#153d29,stroke-dasharray:5 3

    class browser client
    class api,prefetch,gate,cached,runners,tools app
    class gemini,sessions,bank google
    class rdi,cache,ram,context,database redis
    class lake external

    linkStyle default stroke:#334155,stroke-width:2px
