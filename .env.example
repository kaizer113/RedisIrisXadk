# Google Cloud / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_MODEL=gemini-3.1-flash-lite
GOOGLE_MODELS="gemini-3.1-flash-lite gemini-3.1-pro-preview"
VALUEWHOLESALE_VECTOR_SEARCH_ENABLED=true
VALUEWHOLESALE_DEPLOY_REGION=
VALUEWHOLESALE_VM_ZONE=
# Optional private Redis hostname used only by the Compute Engine deployment.
VALUEWHOLESALE_VM_REDIS_HOST=
VALUEWHOLESALE_EMBEDDING_MODEL=redis/langcache-embed-v3-small
VALUEWHOLESALE_EMBEDDING_DEVICE=cpu
VALUEWHOLESALE_EMBEDDING_CACHE_TTL_SECONDS=86400

GOOGLE_MEMORY_LOCATION=
GOOGLE_AGENT_ENGINE_ID=

# Demo identity
VALUEWHOLESALE_DEMO_MEMBER_ID=member-1001
VALUEWHOLESALE_DEMO_SESSION_ID=shopping-demo-1

# Redis Cloud database (catalog, inventory, cart, policy search).
# Keep credentials in your local .env; never commit a live Redis URL here.
REDIS_URL=

# RedisVL Semantic Router. Lower cosine distance is stricter.
VALUEWHOLESALE_SEMANTIC_ROUTER_THRESHOLD=0.48
VALUEWHOLESALE_SEMANTIC_ROUTER_INDEX=valuewholesale-cache-router-v2

# Redis Context Retriever / Context Surfaces
CTX_ADMIN_KEY=cs_admin_xxxxxxxxxxx
CTX_MCP_URL=https://gcp-us-east4.context-surfaces.redis.io/mcp
CTX_SURFACE_ID=
MCP_AGENT_KEY=cs_agent_xxxxxxxx

# Redis LangCache
LANGCACHE_HOST=https://gcp-us-east4.langcache.redis.io
LANGCACHE_CACHE_ID=
LANGCACHE_API_KEY=lc1_xxxxxxxxxx
LANGCACHE_SIMILARITY_THRESHOLD=0.80

# Redis Agent Memory
AGENT_MEMORY_BASE_URL=https://gcp-us-east4.memory.redis.io
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=mem1_xxxxxx
AGENT_MEMORY_NAMESPACE=valuewholesale-shopping
AGENT_MEMORY_SIMILARITY_THRESHOLD=0.30

# Prevent a transient model call from leaving the demo request open indefinitely.
VALUEWHOLESALE_AGENT_TIMEOUT_SECONDS=90
VALUEWHOLESALE_WARMUP_ON_STARTUP=false

# Web server
PORT=8080
LOG_LEVEL=INFO
